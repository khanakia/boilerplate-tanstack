# Code generated by scripts CLI from deploy.yml.tmpl — DO NOT EDIT deploy.[[ .Name ]].yml directly
name: Deploy [[ .Name ]]

on:
  push:
    branches: [[[ .Branch ]]]
  workflow_dispatch:
    inputs:
      skip_build:
        description: 'Skip build and deploy existing latest image'
        type: boolean
        default: false

env:
  REGISTRY: ghcr.io
  IMAGE_NAME: ${{ github.repository }}
  ENVIRONMENT: [[ .Name ]]

jobs:
  build-and-push:
    if: ${{ github.event.inputs.skip_build != 'true' }}
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up QEMU
        uses: docker/setup-qemu-action@v3

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Login to Container Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ secrets.GITHUB_ACTOR }}
          password: ${{ secrets.GHCR_PAT }}

      - name: Docker metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: ${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}
          tags: |
            type=raw,value=[[ .Name ]]-${{ github.sha }}
            type=raw,value=[[ .Name ]]-latest

      - name: Build and push
        uses: docker/build-push-action@v6
        with:
          context: .
          file: .docker/Dockerfile.production
          push: true
          tags: ${{ steps.meta.outputs.tags }}
          labels: ${{ steps.meta.outputs.labels }}
          build-args: |
            VERSION=${{ github.ref_name }}
            COMMIT=${{ github.sha }}
            BRANCH=${{ github.ref_name }}
            BUILD_TIME=${{ github.event.head_commit.timestamp }}
          cache-from: type=gha
          cache-to: type=gha,mode=max

  deploy:
    needs: build-and-push
    if: always() && (needs.build-and-push.result == 'success' || needs.build-and-push.result == 'skipped')
    runs-on: ubuntu-latest
    environment: [[ .Name ]]
    steps:
      - name: Deploy to VPS
        uses: appleboy/ssh-action@v1
        with:
          host: ${{ secrets.VPS_HOST }}
          username: ${{ secrets.VPS_USER }}
          port: ${{ secrets.VPS_PORT }}
          key: ${{ secrets.VPS_SSH_KEY }}
          script: |
            set -e
            DEPLOY_PATH="${{ secrets.DEPLOY_PATH }}"
            CONTAINER_NAME="${{ secrets.CONTAINER_NAME }}"
            IMAGE="${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}:[[ .Name ]]-latest"

            # Create directories
            mkdir -p "$DEPLOY_PATH/_keys" "$DEPLOY_PATH/logs"

            # Decode ENV_B64 to .env file (clean, no GITHUB_SECRET_ lines)
            echo "${{ secrets.[[ .EnvVarName ]] }}" | base64 -d > "$DEPLOY_PATH/.env.[[ .Name ]]"

            # Login to container registry
            echo "${{ secrets.GHCR_PAT }}" | docker login ${{ env.REGISTRY }} -u ${{ secrets.GITHUB_ACTOR }} --password-stdin

            # Pull latest image
            docker pull "$IMAGE"

            # Stop old container
            docker stop "$CONTAINER_NAME" 2>/dev/null || true
            docker rm "$CONTAINER_NAME" 2>/dev/null || true

            # Start new container
            docker run -d \
              --name "$CONTAINER_NAME" \
              --restart unless-stopped \
              --network host \
              --env-file "$DEPLOY_PATH/.env.[[ .Name ]]" \
              -v "$DEPLOY_PATH/_keys:/app/_keys:ro" \
              -v "$DEPLOY_PATH/logs:/app/logs" \
              "$IMAGE"

            # Run migrations
            docker exec "$CONTAINER_NAME" node migrate.mjs || echo "Migration failed or no migrations to run"

            # Prune old images
            docker image prune -f --filter "until=168h"
